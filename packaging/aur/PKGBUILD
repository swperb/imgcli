# Maintainer: swperb <stephenproctor291@gmail.com>
pkgname=imgcli
pkgver=0.3.0
pkgrel=1
pkgdesc="Dependency-free CLI to convert, resize, crop, filter & composite images (ffmpeg-style)"
arch=('x86_64' 'aarch64')
url="https://github.com/swperb/imgcli"
license=('MIT')
depends=('glibc')
makedepends=('gcc' 'make')
source=("$pkgname-$pkgver.tar.gz::https://github.com/swperb/imgcli/archive/refs/tags/v$pkgver.tar.gz")
sha256sums=('ed0ec9e323ceb7c0e68c727a23587c2e1544857de3ad3878875edf679a825bb3')

build() {
  cd "$pkgname-$pkgver"
  make
}

check() {
  cd "$pkgname-$pkgver"
  ./imgcli --version
}

package() {
  cd "$pkgname-$pkgver"
  install -Dm755 imgcli "$pkgdir/usr/bin/imgcli"
  install -Dm644 LICENSE "$pkgdir/usr/share/licenses/$pkgname/LICENSE"
  install -Dm644 README.md "$pkgdir/usr/share/doc/$pkgname/README.md"
}
